# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=llm_platform
MYSQL_USER=llm_user
MYSQL_PASSWORD=llm_pass

# Backend
APP_NAME=Multi LLM Gateway
APP_ENV=prod
LOG_LEVEL=INFO
DB_HOST=mysql
DB_PORT=3306
DB_NAME=llm_platform
DB_USER=llm_user
DB_PASSWORD=llm_pass

# Security
ACCESS_TOKEN=please_change_this_token
MASTER_KEY=replace_if_you_enable_real_encryption

# URL and CORS
PUBLIC_BASE_URL=
CORS_ORIGINS=*

# Uploads and timeout
UPLOAD_DIR=/app/uploads
DEFAULT_TIMEOUT_MS=60000

# OSS (for image URL re-hosting in ImageGenAdapter)
OSS_ENDPOINT=test
OSS_BUCKET=test
OSS_ACCESS_KEY_ID=test
OSS_ACCESS_KEY_SECRET=test
OSS_PREFIX=test
OSS_PUBLIC_BASE_URL=test
