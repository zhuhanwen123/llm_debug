# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=llm_platform
MYSQL_USER=llm_user
MYSQL_PASSWORD=llm_pass

# Backend
APP_NAME=Multi LLM Gateway
APP_ENV=prod
DB_HOST=mysql
DB_PORT=3306
DB_NAME=llm_platform
DB_USER=llm_user
DB_PASSWORD=llm_pass

# Security
ACCESS_TOKEN=please_change_this_token
MASTER_KEY=replace_if_you_enable_real_encryption

# URL and CORS
PUBLIC_BASE_URL=
CORS_ORIGINS=*

# Uploads and timeout
UPLOAD_DIR=/app/uploads
DEFAULT_TIMEOUT_MS=60000
